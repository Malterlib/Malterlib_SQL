Property.CMakeOutputPath_mariadb\-connector\-c: string = `@('.'->MakeAbsolute())`->MakeAbsolute()
%Target "Dll_mariadb-connector-c_pvio_shmem"
{
	Compile
	{
		!!Compile.Type "WindowsResource"
		SearchPath += [
			`@('../../../..'->MakeAbsolute())/External/zlib`->MakeAbsolute(),
			`@('../../../../External/mariadb-connector-c'->MakeAbsolute())/plugins/pvio`->MakeAbsolute(),
			`@('.'->MakeAbsolute())/include`->MakeAbsolute(),
			`@(CMakeIntermediateDirectory)/External_mariadb-connector-c`->MakeAbsolute(),
			`@('../../../../External/mariadb-connector-c'->MakeAbsolute())/plugins/auth`->MakeAbsolute(),
			`@('../../../../External/mariadb-connector-c'->MakeAbsolute())/include`->MakeAbsolute(),
			`@('../../../../External/mariadb-connector-c'->MakeAbsolute())/plugins/compress`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"HAVE_DLOPEN",
			"HAVE_SCHANNEL",
			"HAVE_TLS",
			"HAVE_WINCRYPT",
			"MARIADB_MACHINE_TYPE=\"x86_64\"",
			"MARIADB_SYSTEM_TYPE=\"Windows\"",
			"NOGDI",
			"WIN32_LEAN_AND_MEAN",
			"_CRT_SECURE_NO_WARNINGS",
			"pvio_shmem_EXPORTS"
		]
	}
	Compile
	{
		!!Compile.Type "C"
		SearchPath += [
			`@('../../../..'->MakeAbsolute())/External/zlib`->MakeAbsolute(),
			`@('../../../../External/mariadb-connector-c'->MakeAbsolute())/plugins/pvio`->MakeAbsolute(),
			`@('.'->MakeAbsolute())/include`->MakeAbsolute(),
			`@(CMakeIntermediateDirectory)/External_mariadb-connector-c`->MakeAbsolute(),
			`@('../../../../External/mariadb-connector-c'->MakeAbsolute())/plugins/auth`->MakeAbsolute(),
			`@('../../../../External/mariadb-connector-c'->MakeAbsolute())/include`->MakeAbsolute(),
			`@('../../../../External/mariadb-connector-c'->MakeAbsolute())/plugins/compress`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"HAVE_DLOPEN",
			"HAVE_SCHANNEL",
			"HAVE_TLS",
			"HAVE_WINCRYPT",
			"MARIADB_MACHINE_TYPE=\"x86_64\"",
			"MARIADB_SYSTEM_TYPE=\"Windows\"",
			"NOGDI",
			"WIN32_LEAN_AND_MEAN",
			"_CRT_SECURE_NO_WARNINGS",
			"pvio_shmem_EXPORTS"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Target.Group "External/mariadb-connector-c"
	{
		!!Target.Group undefined
	}
	Target.Type "DynamicLibrary"
	Target.BaseName "mariadb-connector-c_pvio_shmem"
	Target.BaseFileName "pvio_shmem"
	%Group "plugins"
	{
		%Group "pvio"
		{
			%File `@('../../../../External/mariadb-connector-c'->MakeAbsolute())/plugins/pvio/pvio_shmem.c`
			{
				Compile.Type "C"
			}
		}
		%File `@('../../../../External/mariadb-connector-c'->MakeAbsolute())/plugins/plugin.def`
		{
			Compile.Disabled true
		}
	}
	%Group "Windows"
	{
		%Group "x64"
		{
			%Group `@(FullConfiguration)`
			{
				%Group "win"
				{
					%File `@('.'->MakeAbsolute())/win/pvio_shmem.rc`
					{
						Compile.Type "WindowsResource"
					}
				}
			}
		}
	}
}
