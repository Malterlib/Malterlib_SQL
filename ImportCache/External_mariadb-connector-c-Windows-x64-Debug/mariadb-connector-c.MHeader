			`@('../../../../External/mariadb-connector-c'->MakeAbsolute())/libmariadb`->MakeAbsolute(),
			`@('../../../../External/mariadb-connector-c'->MakeAbsolute())/plugins/auth/ref10`->MakeAbsolute(),
			`@('../../../../External/mariadb-connector-c'->MakeAbsolute())/win-iconv`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"HAVE_DLOPEN",
			"HAVE_SCHANNEL",
			"HAVE_TLS",
			"HAVE_WINCRYPT",
			"MARIADB_MACHINE_TYPE=\"x86_64\"",
			"MARIADB_SYSTEM_TYPE=\"Windows\"",
			"NOGDI",
			"SIZEOF_CHARP=8",
			"WIN32_LEAN_AND_MEAN",
			"_CRT_SECURE_NO_WARNINGS",
			"libmariadb_EXPORTS"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Target.Group "External/mariadb-connector-c"
	{
		!!Target.Group undefined
	}
	Target.Type "SharedDynamicLibrary"
	Target.BaseName "mariadb-connector-c_libmariadb"
	Target.BaseFileName "libmariadb"
	%Group "Windows"
	{
		%Group "x64"
		{
			%Group `@(FullConfiguration)`
			{
				%Group "win"
				{
					%File `@('.'->MakeAbsolute())/win/libmariadb.rc`
					{
						Compile.Type "WindowsResource"
					}
				}
				%Group "libmariadb"
				{
					%File `@('.'->MakeAbsolute())/libmariadb/mariadbclient.def`
					{
						Compile.Disabled true
					}
					%File `@('.'->MakeAbsolute())/libmariadb/ma_client_plugin.c`
					{
						Compile.Type "C"
					}
				}
			}
		}
	}
